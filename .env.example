# Lead Researcher — Environment Variables
# Copy this file to .env and fill in your keys.
# No keys are strictly required for base functionality.

# Tavily API key (optional — enables news search via Tavily)
# Free tier: 1000 searches/month. Get yours at https://tavily.com
# If not set, the tool falls back to DuckDuckGo HTML scraping.
TAVILY_API_KEY=

# LinkedIn Cookie (optional — for enriched contact/employee data)
# Usage: copy cookies from a logged-in LinkedIn session as Netscape format.
# See scripts/import_cookies.sh for setup.
LINKEDIN_COOKIES_PATH=

# Proxies (optional — for burner/rotating IP mode, e.g. for sensitive recon)
HTTP_PROXY=
HTTPS_PROXY=